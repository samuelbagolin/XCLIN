{
  "entities": {
    "Clinic": {
      "title": "Clinic",
      "description": "Clinic settings and profile",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the clinic" },
        "logoUrl": { "type": "string", "description": "URL of the clinic logo" },
        "address": { "type": "string", "description": "Physical address" },
        "phone": { "type": "string", "description": "Contact phone" },
        "ownerId": { "type": "string", "description": "User ID of the clinic owner" },
        "ownerPhone": { "type": "string", "description": "Owner phone" },
        "ownerEmail": { "type": "string", "description": "Owner email" },
        "status": { "type": "string", "enum": ["active", "pending", "blocked", "cancelled"], "description": "Account status" },
        "approvedAt": { "type": "string", "format": "date-time" },
        "approvedBy": { "type": "string" }
      },
      "required": ["name", "ownerId", "status"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Profile data for users (clinic_admins, professionals, staff, patients)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["clinic_admin", "professional", "receptionist", "patient", "financial", "secretary", "super_admin"] },
        "status": { "type": "string", "enum": ["active", "pending", "blocked"] },
        "clinicId": { "type": "string" },
        "professionalId": { "type": "string", "description": "Linked professional document ID if role is professional" }
      },
      "required": ["uid", "email", "role", "clinicId"]
    },
    "Professional": {
      "title": "Professional",
      "description": "Health professional details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "specialties": { "type": "array", "items": { "type": "string" } },
        "clinicId": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["name", "clinicId"]
    },
    "Patient": {
      "title": "Patient",
      "description": "Patient basic data",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "birthDate": { "type": "string" },
        "type": { "type": "string", "enum": ["adult", "child"] },
        "cpf": { "type": "string" },
        "fatherName": { "type": "string" },
        "motherName": { "type": "string" },
        "address": { 
          "type": "object",
          "properties": {
            "street": { "type": "string" },
            "number": { "type": "string" },
            "complement": { "type": "string" },
            "neighborhood": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "zipCode": { "type": "string" }
          }
        },
        "clinicId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "clinicId"]
    },
    "Document": {
      "title": "Document",
      "description": "Contracts and generated documents",
      "type": "object",
      "properties": {
        "clinicId": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "type": { "type": "string", "enum": ["service_contract", "school_visit", "cancellation_policy"] },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "sent", "viewed", "signed", "refused", "expired"] },
        "value": { "type": "number" },
        "signedAt": { "type": "string", "format": "date-time" },
        "signedBy": { "type": "string" },
        "signatureIp": { "type": "string" },
        "sentAt": { "type": "string", "format": "date-time" },
        "viewedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Scheduled appointment",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "professionalId": { "type": "string" },
        "professionalName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled", "no-show", "waiting"] },
        "type": { "type": "string" },
        "clinicId": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "professionalId", "startTime", "endTime", "status", "clinicId"]
    },
    "MedicalRecord": {
      "title": "Medical Record",
      "description": "Clinical notes/evolution",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "professionalId": { "type": "string" },
        "professionalName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["evaluation", "evolution", "document"] },
        "clinicId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "professionalId", "date", "content", "category", "clinicId"]
    },
    "Specialty": {
      "title": "Specialty",
      "description": "Clinical specialties",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "clinicId": { "type": "string" }
      },
      "required": ["name", "clinicId"]
    },
    "FinancialTransaction": {
      "title": "Financial Transaction",
      "description": "Income or expense",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["paid", "pending"] },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "linkedAppointmentId": { "type": "string" },
        "clinicId": { "type": "string" }
      },
      "required": ["type", "amount", "date", "clinicId"]
    },
    "AdminLog": {
      "title": "Admin Log",
      "description": "Log of admin actions",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "clinicId": { "type": "string" },
        "clinicName": { "type": "string" },
        "performedBy": { "type": "string" },
        "performedByName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["action", "performedBy", "timestamp"]
    }
  },
  "firestore": {
    "/clinics/{clinicId}": {
      "schema": "Clinic",
      "description": "Clinic settings"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/professionals/{profId}": {
      "schema": "Professional",
      "description": "Professional details"
    },
    "/patients/{patientId}": {
      "schema": "Patient",
      "description": "Patient data"
    },
    "/documents/{docId}": {
      "schema": "Document",
      "description": "Patient documents and contracts"
    },
    "/appointments/{appId}": {
      "schema": "Appointment",
      "description": "Clinic appointments"
    },
    "/medicalRecords/{recordId}": {
      "schema": "MedicalRecord",
      "description": "Patient evolution records"
    },
    "/specialties/{specId}": {
      "schema": "Specialty",
      "description": "Clinical specialties"
    },
    "/financialTransactions/{transId}": {
      "schema": "FinancialTransaction",
      "description": "Financial flow"
    },
    "/admin_logs/{logId}": {
      "schema": "AdminLog",
      "description": "Administrator action logs"
    }
  }
}
