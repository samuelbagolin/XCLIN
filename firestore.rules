rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }
    
    function isClinicActive() {
      let uData = getUserData();
      if (uData == null || !uData.keys().contains('clinicId') || uData.get('clinicId', '') == '') {
        return true;
      }
      let cPath = /databases/$(database)/documents/clinics/$(uData.clinicId);
      return exists(cPath) && get(cPath).data.get('status', '') == 'active';
    }
    
    function isClinicAdmin() {
      let uData = getUserData();
      return isSignedIn() && uData != null && uData.get('role', '') == 'clinic_admin' && isClinicActive();
    }
    
    function isStaff() {
      let uData = getUserData();
      if (uData == null) return false;
      let role = uData.get('role', '');
      return isSignedIn() && 
             isClinicActive() &&
             (role == 'clinic_admin' || role == 'receptionist' || role == 'professional' || role == 'financial' || role == 'secretary');
    }
    
    function userClinicId() {
      let uData = getUserData();
      return uData != null ? uData.get('clinicId', '') : '';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // --- Collections ---

    // Clinics
    match /clinics/{clinicId} {
      allow get: if isSignedIn(); 
      allow create: if isSignedIn() && isValidId(clinicId) && request.resource.data.status == 'active';
      allow update: if isClinicAdmin() && clinicId == userClinicId() && 
                    request.resource.data.status == resource.data.status; // Admins can't unblock themselves
    }

    // User Profiles
    match /users/{userId} {
      allow get: if isSignedIn() && (userId == request.auth.uid || isClinicAdmin());
      allow list: if isClinicAdmin() && resource.data.get('clinicId', '') == userClinicId();
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (userId == request.auth.uid || isClinicAdmin());
      allow delete: if isClinicAdmin() && resource.data.get('clinicId', '') == userClinicId();
    }

    // Documents
    match /documents/{docId} {
      allow get: if true; // Public access for signature (hardened via docId and status check)
      allow list: if isSignedIn() && isClinicActive() && resource.data.clinicId == userClinicId();
      allow create: if isSignedIn() && isClinicActive();
      allow update: if (isSignedIn() && isClinicActive() && resource.data.clinicId == userClinicId()) || 
                    (resource.data.status != 'signed' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'signedAt', 'signedBy', 'signatureIp', 'viewedAt']));
      allow delete: if isSignedIn() && isClinicActive() && resource.data.clinicId == userClinicId();
    }

    // Professionals
    match /professionals/{profId} {
      allow get, list: if isStaff() && resource.data.clinicId == userClinicId();
      allow create, update, delete: if isClinicAdmin();
    }

    // Patients
    match /patients/{patientId} {
      allow get, list: if isStaff() && resource.data.clinicId == userClinicId();
      allow create: if isStaff();
      allow update: if isStaff() && resource.data.clinicId == userClinicId();
      allow delete: if isClinicAdmin() && resource.data.clinicId == userClinicId();
    }

    // Appointments
    match /appointments/{appId} {
      allow get, list: if isStaff() && resource.data.clinicId == userClinicId();
      allow create: if isStaff() && request.resource.data.clinicId == userClinicId();
      allow update: if isStaff() && resource.data.clinicId == userClinicId();
      allow delete: if isStaff() && resource.data.clinicId == userClinicId();
    }

    // Medical Records
    match /medicalRecords/{recordId} {
      allow get, list: if (isStaff()) && resource.data.clinicId == userClinicId();
      allow create: if (isStaff()) && request.resource.data.clinicId == userClinicId();
      allow update, delete: if (isStaff()) && resource.data.clinicId == userClinicId();
    }

    // Specialties
    match /specialties/{specId} {
      allow get, list: if isSignedIn() && resource.data.clinicId == userClinicId();
      allow create, update, delete: if isClinicAdmin();
    }

    // Financial Transactions
    match /financialTransactions/{transId} {
      allow get, list: if isStaff() && resource.data.clinicId == userClinicId();
      allow create: if isStaff() && request.resource.data.clinicId == userClinicId();
      allow update, delete: if isStaff() && resource.data.clinicId == userClinicId();
    }
  }
}
