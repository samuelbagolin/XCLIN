rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isSuperAdmin() {
      let uData = getUserData();
      return isSignedIn() && uData != null && uData.role == 'super_admin';
    }
    
    function getClinicData(clinicId) {
      let path = /databases/$(database)/documents/clinics/$(clinicId);
      return exists(path) ? get(path).data : null;
    }

    function isClinicActive(clinicId) {
      let cData = getClinicData(clinicId);
      return cData != null && cData.status == 'active';
    }

    function isClinicPending(clinicId) {
      let cData = getClinicData(clinicId);
      return cData != null && cData.status == 'pending';
    }

    function userClinicId() {
      let uData = getUserData();
      return uData != null ? uData.get('clinicId', '') : '';
    }

    function isStaff(clinicId) {
      let uData = getUserData();
      if (uData == null || uData.get('clinicId', '') != clinicId) return false;
      let role = uData.get('role', '');
      return isSignedIn() && (role == 'clinic_admin' || role == 'professional' || role == 'receptionist' || role == 'financial' || role == 'secretary');
    }

    function isClinicAdmin(clinicId) {
      let uData = getUserData();
      return isSignedIn() && uData != null && uData.role == 'clinic_admin' && uData.clinicId == clinicId;
    }

    // --- Collections ---

    // Clinics
    match /clinics/{clinicId} {
      allow get: if isSignedIn() && (isSuperAdmin() || clinicId == userClinicId());
      allow list: if isSuperAdmin();
      allow create: if isSignedIn() && request.resource.data.status == 'pending';
      allow update: if isSuperAdmin() || (isClinicAdmin(clinicId) && request.resource.data.status == resource.data.status);
      allow delete: if isSuperAdmin();
    }

    // Users
    match /users/{userId} {
      allow get: if isSignedIn() && (userId == request.auth.uid || isSuperAdmin() || isClinicAdmin(userClinicId()));
      allow list: if isSuperAdmin() || (isClinicAdmin(userClinicId()));
      allow create: if isSignedIn() && request.resource.data.role != 'super_admin';
      allow update: if isSuperAdmin() || 
                    (userId == request.auth.uid && request.resource.data.role == resource.data.role && request.resource.data.status == resource.data.status) ||
                    (isClinicAdmin(userClinicId()) && request.resource.data.clinicId == resource.data.clinicId);
      allow delete: if isSuperAdmin() || (isClinicAdmin(userClinicId()) && resource.data.clinicId == userClinicId());
    }

    // Protected Business Data (Active Clinic Only)
    match /patients/{id} {
      allow read: if isSuperAdmin() || (isStaff(resource.data.clinicId) && isClinicActive(resource.data.clinicId));
      allow create: if isSuperAdmin() || (isStaff(request.resource.data.clinicId) && isClinicActive(request.resource.data.clinicId));
      allow update: if isSuperAdmin() || (isStaff(resource.data.clinicId) && isClinicActive(resource.data.clinicId));
      allow delete: if isSuperAdmin() || (isClinicAdmin(resource.data.clinicId) && isClinicActive(resource.data.clinicId));
    }

    match /appointments/{id} {
      allow read: if isSuperAdmin() || (isStaff(resource.data.clinicId) && isClinicActive(resource.data.clinicId));
      allow write: if isSuperAdmin() || (isStaff(request.resource.data.clinicId || resource.data.clinicId) && isClinicActive(request.resource.data.clinicId || resource.data.clinicId));
    }

    match /financialTransactions/{id} {
      allow read: if isSuperAdmin() || (isStaff(resource.data.clinicId) && isClinicActive(resource.data.clinicId));
      allow write: if isSuperAdmin() || (isStaff(request.resource.data.clinicId || resource.data.clinicId) && isClinicActive(request.resource.data.clinicId || resource.data.clinicId));
    }

    match /professionals/{id} {
      allow read: if isSuperAdmin() || (isStaff(resource.data.clinicId) && isClinicActive(resource.data.clinicId));
      allow write: if isSuperAdmin() || (isClinicAdmin(request.resource.data.clinicId || resource.data.clinicId) && isClinicActive(request.resource.data.clinicId || resource.data.clinicId));
    }

    match /documents/{id} {
      allow get: if true; // Public access for signatures
      allow list: if isSuperAdmin() || (isStaff(resource.data.clinicId) && isClinicActive(resource.data.clinicId));
      allow create: if isSuperAdmin() || (isStaff(request.resource.data.clinicId) && isClinicActive(request.resource.data.clinicId));
      allow update: if isSuperAdmin() || (isStaff(resource.data.clinicId) && isClinicActive(resource.data.clinicId)) || (resource.data.status != 'signed' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'signedAt', 'signedBy', 'signatureIp', 'viewedAt']));
      allow delete: if isSuperAdmin() || (isClinicAdmin(resource.data.clinicId) && isClinicActive(resource.data.clinicId));
    }

    match /medicalRecords/{id} {
      allow read, write: if isSuperAdmin() || (isStaff(resource.data.clinicId || request.resource.data.clinicId) && isClinicActive(resource.data.clinicId || request.resource.data.clinicId));
    }

    match /specialties/{id} {
      allow read: if isSuperAdmin() || (isStaff(resource.data.clinicId) && isClinicActive(resource.data.clinicId));
      allow write: if isSuperAdmin() || (isClinicAdmin(resource.data.clinicId || request.resource.data.clinicId) && isClinicActive(resource.data.clinicId || request.resource.data.clinicId));
    }

    // Logs
    match /admin_logs/{id} {
      allow read, write: if isSuperAdmin();
    }
  }
}
